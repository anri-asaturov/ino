{
  "name": "@ino/backend",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./api-types.ts",
  "exports": {
    ".": {
      "types": "./api-types.ts",
      "import": "./dist/src/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "api-types.ts"
  ],
  "scripts": {
    "build": "pnpm prisma generate && tsc -b",
    "dev": "pnpm prisma generate && PORT=3007 tsx watch --clear-screen=false src/index.ts",
    "debug": "pnpm prisma generate && PORT=3007 tsx watch --inspect src/index.ts",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "test:integration": "pnpm prisma generate && vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^2.1.4",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/request-context": "^7.0.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "7.8.0",
    "@trpc/server": "11.18.0",
    "@types/node": "26.1.0",
    "@vitest/coverage-v8": "^4.1.9",
    "fastify": "^5.9.0",
    "fastify-graceful-shutdown": "^5.0.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prisma": "7.8.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "zod": "^4.4.3"
  }
}
