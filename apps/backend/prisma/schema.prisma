//  Model definition sorting system
//
// 1. Plain columns
// 2. Foreign key columns
// 3. Relations
// 4. Created at, Updated at
// 5. Indexes
//
// Add empty lines between each section

generator client {
    provider = "prisma-client"
    output   = "../generated/prisma"
}

datasource db {
    provider = "postgresql"
}

model Patient {
    id String @id

    birthdate String @db.VarChar(10)
    gender    Int
    ethnicity Int

    labResults LabResult[]

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    @@map("patients")
}

model LabResult {
    id String @id @default(cuid())

    date               String  @db.VarChar(10)
    creatine           Decimal @db.Decimal(10, 2)
    chloride           Decimal @db.Decimal(10, 2)
    fastingGlucose     Decimal @map("fasting_glucose") @db.Decimal(10, 2)
    potassium          Decimal @db.Decimal(10, 2)
    sodium             Decimal @db.Decimal(10, 2)
    totalCalcium       Decimal @map("total_calcium") @db.Decimal(10, 2)
    totalProtein       Decimal @map("total_protein") @db.Decimal(10, 2)
    creatineUnit       String  @map("creatine_unit")
    chlorideUnit       String  @map("chloride_unit")
    fastingGlucoseUnit String  @map("fasting_glucose_unit")
    potassiumUnit      String  @map("potassium_unit")
    sodiumUnit         String  @map("sodium_unit")
    totalCalciumUnit   String  @map("total_calcium_unit")
    totalProteinUnit   String  @map("total_protein_unit")

    patientId String @map("patient_id")

    patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    @@unique([patientId, date])
    // serves the time series keyset pagination sort
    @@index([date(sort: Desc), id])
    @@map("lab_results")
}
